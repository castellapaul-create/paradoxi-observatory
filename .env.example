# PARADOXI Observatory — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# ─── Resend (emails transactionnels) ──────────────────────────────────────────
# 1. Créer un compte sur https://resend.com (gratuit, 3000 emails/mois)
# 2. Créer une API key dans Settings > API Keys

RESEND_API_KEY=VOTRE_CLE_RESEND_ICI

# Audience ID — gérer la liste d'abonnés dans Resend > Audiences
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Adresse expéditeur (doit correspondre à un domaine vérifié dans Resend)
# En dev, "onboarding@resend.dev" fonctionne sans vérification de domaine
FROM_EMAIL=PARADOXI Observatory <newsletter@paradoxi.io>

# ─── Google Sheets (track record abonnés) ─────────────────────────────────────
# 1. Aller sur https://console.cloud.google.com
# 2. Créer un projet > Activer l'API "Google Sheets"
# 3. IAM & Admin > Comptes de service > Créer un compte > Télécharger la clé JSON
# 4. Créer un Google Sheet > Renommer la 1ère feuille "Abonnés"
#    Colonnes : A=Timestamp | B=Email | C=Source | D=Status
# 5. Partager le sheet avec l'email du service account (éditeur)
# 6. Copier l'ID du sheet depuis l'URL : docs.google.com/spreadsheets/d/[ID]/edit

GOOGLE_SA_EMAIL=paradoxi-sheets@votre-projet.iam.gserviceaccount.com
# Clé privée du service account (copier la valeur "private_key" du JSON téléchargé)
GOOGLE_SA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (paiement abonnement premium) ─────────────────────────────────────
# 1. Créer un compte sur https://stripe.com (gratuit, 2.9% + 0.30€ par transaction)
# 2. Dashboard > Produits > Créer un produit "PARADOXI Observatory Premium"
#    - Prix récurrent : 69€/mois
# 3. Copier la clé secrète (Developers > API keys) et l'ID du prix (Price ID)
# 4. Pour activer les paiements : configurer l'URL du site dans Stripe Dashboard

STRIPE_SECRET_KEY=VOTRE_CLE_STRIPE_ICI
STRIPE_PRICE_ID=VOTRE_PRICE_ID_STRIPE_ICI

# URL publique du site (pour les redirections Stripe success/cancel)
PUBLIC_URL=https://paradoxi.vercel.app

# ─── Environnement ────────────────────────────────────────────────────────────
NODE_ENV=development
